[Desktop Entry]
Type=Application
_Name=PaintBrush
_GenericName=Image Editor
_Comment=Simple painting and drawing application
Exec=paintbrush %F
Icon=com.danielnylander.paintbrush
Terminal=false
StartupNotify=true
Categories=Graphics;2DGraphics;RasterGraphics;GTK;
_Keywords=paint;draw;brush;image;layers;crop;gradient;
MimeType=image/png;image/jpeg;image/gif;image/bmp;image/webp;image/svg+xml;image/tiff;
